# =============================================================================
# Modell- und Profilsteuerung
# =============================================================================
# Optionales Modellprofil aus prototype/config/model_profiles.yaml.
# Leer lassen, wenn die einzelnen LLM- und Embedding-Werte unten gelten sollen.
ACTIVE_MODEL_PROFILE=


# =============================================================================
# LLM-Konfiguration
# =============================================================================
# Mögliche Werte: ollama, openai
LLM_PROVIDER=ollama

# Lokales LLM über Ollama.
OLLAMA_MODEL=llama3.1
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# OpenAI-LLM. OPENAI_API_KEY nur setzen, wenn OpenAI genutzt wird.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Temperatur für LLM-Aufrufe, sofern kein Modellprofil oder Step-Override greift.
TEMPERATURE=0


# =============================================================================
# Embedding-Konfiguration
# =============================================================================
# Mögliche Werte: local, openai, online
EMBEDDING_PROVIDER=local

# Lokales Embedding-Modell. Das Modell wird beim ersten lokalen Aufruf geladen,
# falls es noch nicht im lokalen Modellverzeichnis vorhanden ist.
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI-Embedding-Modell, wenn EMBEDDING_PROVIDER=openai oder online ist.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# Mailpit und operativer E-Mail-Prototyp
# =============================================================================
MAILPIT_API_URL=http://localhost:8025/api/v1
MAILPIT_INBOX_ADDRESS=buergeranliegen@kommune.test
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025

CENTRAL_POSTBOX_NAME="KI-Posteingang Musterstadt"
CENTRAL_POSTBOX_ADDRESS=buergeranliegen@kommune.test

# Standard-Pipeline und Polling-Intervall des E-Mail-Workers.
OPERATIONS_VERSION=V5
EMAIL_POLL_SECONDS=10


# =============================================================================
# Logging
# =============================================================================
PROTOTYPE_LOG_LEVEL=INFO
